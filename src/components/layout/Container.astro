---
export interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full'
  class?: string
  id?: string
}

const { size = 'lg', class: className, id } = Astro.props

const sizeClasses = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-7xl',
  xl: 'max-w-[1400px]',
  full: 'max-w-full',
}
---

<div id={id} class={`container mx-auto px-4 sm:px-6 lg:px-8 ${sizeClasses[size]} ${className ?? ''}`}>
  <slot />
</div>
