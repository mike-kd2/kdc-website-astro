---
export interface Props {
  spacing?: 'sm' | 'md' | 'lg' | 'xl' | 'none'
  background?: 'white' | 'gray' | 'primary' | 'none'
  class?: string
  id?: string
}

const { spacing = 'lg', background = 'none', class: className, id } = Astro.props

const spacingClasses = {
  none: '',
  sm: 'py-8 md:py-12',
  md: 'py-12 md:py-16',
  lg: 'py-16 md:py-24',
  xl: 'py-24 md:py-32',
}

const backgroundClasses = {
  none: '',
  white: 'bg-white',
  gray: 'bg-neutral-off-white',
  primary: 'bg-primary text-white',
}
---

<section id={id} class={`${spacingClasses[spacing]} ${backgroundClasses[background]} ${className ?? ''}`}>
  <slot />
</section>
