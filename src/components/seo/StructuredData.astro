---
export interface Props {
  type?: 'website' | 'organization' | 'service' | 'article' | 'person'
  pageTitle?: string
  pageDescription?: string
  pagePath?: string
}


const {
  type = 'website',
  pageTitle,
  pageDescription,
  pagePath = '',
} = Astro.props

const baseUrl = 'https://klauserdesigns.ch'
const fullUrl = `${baseUrl}${pagePath}`

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${baseUrl}/#organization`,
  name: 'klauser designs',
  alternateName: 'kd',
  url: baseUrl,
  logo: `${baseUrl}/logo.png`,
  description:
    'Automatisierung, massgeschneiderte Tools und Datenlösungen für Schweizer Verbände und KMUs. Spezialisiert auf Prozessautomatisierung, individuelle Software-Entwicklung und Datenintegration.',
  email: 'michael@klauserdesigns.ch',
  telephone: '+41796915598',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Notkerstrasse 14',
    postalCode: '9000',
    addressLocality: 'St. Gallen',
    addressRegion: 'SG',
    addressCountry: 'CH',
  },
  founder: {
    '@type': 'Person',
    name: 'Michael Klauser',
    jobTitle: 'Systemtechnik-Ingenieur & Automatisierungs-Spezialist',
    description:
      'IT-Experte mit über 20 Jahren Erfahrung in Software-Entwicklung, Systemintegration und Prozessautomatisierung',
  },
  areaServed: {
    '@type': 'Country',
    name: 'Switzerland',
  },
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${baseUrl}/#website`,
  url: baseUrl,
  name: 'klauser designs',
  description:
    'Automatisierung, massgeschneiderte Tools und Datenlösungen für Schweizer Verbände und KMUs',
  publisher: { '@id': `${baseUrl}/#organization` },
  inLanguage: 'de-CH',
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Automatisierung & Datenlösungen',
  provider: { '@id': `${baseUrl}/#organization` },
  areaServed: { '@type': 'Country', name: 'Switzerland' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Automatisierung, Tools & Datenlösungen',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Prozesse automatisieren',
          description: 'Wiederkehrende Abläufe automatisieren und manuelle Arbeit reduzieren',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Massgeschneiderte Tools entwickeln',
          description: 'Individuelle Software-Tools, die genau zu Ihren Anforderungen passen',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Daten nutzbar machen',
          description: 'Datenintegration, Reporting und Data Warehouse für fundierte Entscheidungen',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Systeme wechseln, Daten mitnehmen',
          description: 'Sichere Datenmigration und Systemwechsel ohne Datenverlust',
        },
      },
    ],
  },
}

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${baseUrl}/#localbusiness`,
  name: 'klauser designs',
  url: baseUrl,
  email: 'michael@klauserdesigns.ch',
  telephone: '+41796915598',
  description:
    'Freelance Spezialist für Prozessautomatisierung, massgeschneiderte Software und Datenlösungen für Verbände und KMUs in der Deutschschweiz. Selbstständig seit 2013.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Notkerstrasse 14',
    postalCode: '9000',
    addressLocality: 'St. Gallen',
    addressRegion: 'SG',
    addressCountry: 'CH',
  },
  areaServed: { '@type': 'AdministrativeArea', name: 'Deutschschweiz' },
  priceRange: 'CHF CHF',
  knowsAbout: [
    'Prozessautomatisierung',
    'Datenmigration',
    'Data Warehouse',
    'ETL-Pipelines',
    'Power BI',
    'Microsoft Dynamics 365',
    'Python',
    'C#',
    'SQL Server',
    'KI-Integration',
  ],
  founder: { '@id': `${baseUrl}/#person` },
}

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${baseUrl}/#person`,
  name: 'Michael Klauser',
  jobTitle: 'Dipl. Systemtechnik-Ingenieur FH',
  description:
    'Freelance IT-Spezialist für Prozessautomatisierung, Datenlösungen und massgeschneiderte Software. Selbstständig seit 2013.',
  url: `${baseUrl}/ueber-mich`,
  email: 'michael@klauserdesigns.ch',
  worksFor: { '@id': `${baseUrl}/#organization` },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Notkerstrasse 14',
    postalCode: '9000',
    addressLocality: 'St. Gallen',
    addressCountry: 'CH',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'NTB Buchs — Interstaatliche Hochschule für Technik',
  },
  knowsAbout: [
    'Prozessautomatisierung',
    'Datenmigration',
    'Data Warehouse',
    'SQL Server',
    'C#',
    'Python',
    'Power BI',
    'Microsoft Dynamics 365',
    'SAP-Integration',
    'KI-Integration',
  ],
}

const breadcrumbSchema =
  pagePath && pagePath !== '/'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
          { '@type': 'ListItem', position: 2, name: pageTitle || 'Seite', item: fullUrl },
        ],
      }
    : null

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': fullUrl,
  url: fullUrl,
  name: pageTitle || 'klauser designs & coaching',
  description:
    pageDescription ||
    'Automatisierung, massgeschneiderte Tools und Datenlösungen für Schweizer Verbände und KMUs',
  isPartOf: { '@id': `${baseUrl}/#website` },
  about: { '@id': `${baseUrl}/#organization` },
  inLanguage: 'de-CH',
}

const schemas: unknown[] = [organizationSchema, localBusinessSchema, websiteSchema, webPageSchema]
if (type === 'service') schemas.push(serviceSchema)
if (type === 'person') schemas.push(personSchema)
if (breadcrumbSchema) schemas.push(breadcrumbSchema)
---

<script type="application/ld+json" set:html={JSON.stringify(schemas)} />
