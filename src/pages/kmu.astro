---
import BaseLayout from '../layouts/BaseLayout.astro'
import StructuredData from '../components/seo/StructuredData.astro'
import Container from '../components/layout/Container.astro'
import Section from '../components/layout/Section.astro'
import LeistungsBlock from '../components/ui/LeistungsBlock.astro'
---

<BaseLayout
  title="Prozessautomatisierung & Datenlösungen für Schweizer KMUs"
  description="Datenflüsse automatisieren, Reporting und Systemmigrationen für Schweizer KMUs."
>
  <StructuredData
    type="service"
    pageTitle="Prozessautomatisierung & Datenlösungen für Schweizer KMUs"
    pageDescription="Datenflüsse automatisieren, Reporting und Systemmigrationen für Schweizer KMUs."
    pagePath="/kmu"
  />

  <!-- Hero Section -->
  <section class="relative bg-primary overflow-hidden py-16 text-white md:py-24">
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 64px 64px;"
    />
    <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full bg-primary-light opacity-40 blur-3xl pointer-events-none" />
    <div class="absolute -bottom-16 left-1/3 w-48 h-48 rounded-full bg-accent opacity-15 blur-2xl pointer-events-none" />

    <Container size="md">
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">
            Für KMUs
          </p>
          <h1 class="mb-6 text-3xl font-bold sm:text-4xl lg:text-5xl max-w-2xl">
            Ihre Systeme reden nicht miteinander? Ich baue die Brücke.
          </h1>
          <p class="text-lg text-white/75 max-w-lg">
            Ihre Daten stecken in fünf Systemen, Ihr Reporting kostet Tage,
            und bei jedem Systemwechsel hofft jemand, dass nichts verloren
            geht. Ich baue die Verbindungen und Werkzeuge, die Ihnen das
            manuelle Hin und Her abnehmen.
          </p>
        </div>

        <div class="hidden lg:flex flex-col gap-3">
          <p class="text-white/40 text-xs uppercase tracking-widest mb-1">Kommt Ihnen bekannt vor?</p>
          {[
            'Reporting braucht Tage statt Minuten',
            'Daten müssen manuell zwischen Systemen kopiert werden',
            'Beim Systemwechsel hofft jemand, dass nichts verloren geht',
            'Kein einheitliches Bild über alle Daten',
          ].map((item) => (
            <div class="flex items-center gap-3 rounded-md bg-white/[0.06] border border-white/10 px-4 py-3">
              <span class="w-1.5 h-1.5 rounded-full bg-white/30 flex-shrink-0" />
              <span class="text-white/60 text-sm">{item}</span>
            </div>
          ))}
          <div class="mt-2 text-accent text-sm font-semibold">
            ↓ Genau dafür bin ich da.
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Leistungsblöcke Section -->
  <Section spacing="lg">
    <Container size="md">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">
        Leistungen
      </p>
      <h2 class="mb-8 text-3xl font-bold text-neutral-charcoal sm:text-4xl">
        Was ich baue
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <LeistungsBlock
          nummer={1}
          titel="Datenflüsse automatisieren"
          text="System-zu-System-Integration: Import, Export, Synchronisation. Automatisch statt per Copy-Paste."
        />
        <LeistungsBlock
          nummer={2}
          titel="Reporting & Dashboards"
          text="Von Excel zu Power BI: Dashboards, die sich selbst aktualisieren und Entscheidungsgrundlagen liefern."
        />
        <LeistungsBlock
          nummer={3}
          titel="Systemwechsel & Datenmigrationen"
          text="ERP/CRM-Migrationen mit 100%-Validierung über die gesamte Datenbasis. Nicht Stichproben. Alles."
        />
        <LeistungsBlock
          nummer={4}
          titel="Massgeschneiderte Software"
          text="Wenn Standardlösungen nicht passen: Backend-Systeme, Middleware, Integrationen. Gebaut für Ihren konkreten Ablauf."
        />
      </div>
    </Container>
  </Section>

  <!-- Referenz-Hinweis -->
  <section class="bg-white py-16 border-t border-neutral-light-gray">
    <Container size="md">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">
        Aus der Praxis
      </p>
      <h2 class="text-2xl font-bold text-neutral-charcoal mb-8">
        Zwei Beispiele, die das zeigen.
      </h2>
      <div class="flex flex-col gap-4">
        <!-- Helion -->
        <div class="rounded-xl bg-neutral-off-white border border-neutral-light-gray overflow-hidden shadow-card">
          <div class="px-8 pt-7 pb-5 border-b border-neutral-light-gray">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="font-bold text-neutral-charcoal text-lg">Helion Energy AG</span>
              <span class="rounded-full bg-primary/[0.08] text-primary px-3 py-0.5 text-xs font-medium">
                Energieunternehmen
              </span>
              <span class="rounded-full bg-accent/10 text-accent px-3 py-0.5 text-xs font-semibold">
                2013 – 2025
              </span>
            </div>
            <p class="text-primary font-semibold text-lg leading-snug border-l-4 border-accent pl-4">
              Reportingzeit von Tagen auf Minuten reduziert. Alle Geschäftsbereiche auf demselben Datenstand.
            </p>
          </div>
          <div class="px-8 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <p class="text-neutral-slate text-sm">
              Data Warehouse, Azure-Middleware, ERP-Migration — 10 Jahre aufgebaut und betrieben.
            </p>
            <a
              href="/referenzen#helion-dw"
              class="text-primary font-semibold text-sm hover:underline whitespace-nowrap flex-shrink-0"
            >
              Zum Projekt →
            </a>
          </div>
        </div>

        <!-- SBKH -->
        <div class="rounded-xl bg-neutral-off-white border border-neutral-light-gray overflow-hidden shadow-card">
          <div class="px-8 pt-7 pb-5 border-b border-neutral-light-gray">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="font-bold text-neutral-charcoal text-lg">SBKH GmbH</span>
              <span class="rounded-full bg-primary/[0.08] text-primary px-3 py-0.5 text-xs font-medium">
                E-Commerce / Preisvergleich
              </span>
              <span class="rounded-full bg-accent/10 text-accent px-3 py-0.5 text-xs font-semibold">
                2019 – 2020
              </span>
            </div>
            <p class="text-primary font-semibold text-lg leading-snug border-l-4 border-accent pl-4">
              Null manueller Aufwand. Sortiment wächst ohne zusätzliches Personal.
            </p>
          </div>
          <div class="px-8 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <p class="text-neutral-slate text-sm">
              Vollautomatisierte Pipeline: tägliche Abholung, Transformation und Einspielung aus mehreren Quellen.
            </p>
            <a
              href="/referenzen#sbkh"
              class="text-primary font-semibold text-sm hover:underline whitespace-nowrap flex-shrink-0"
            >
              Zum Projekt →
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16 text-white">
    <Container size="md">
      <p class="mb-2 text-2xl font-semibold sm:text-3xl">
        Welcher Ablauf frisst bei Ihnen am meisten Zeit?
      </p>
      <p class="text-white/60 mb-8 max-w-md">
        Im Prozess-Check schauen wir uns gemeinsam an, was sich als erstes angehen lässt.
      </p>
      <a
        href="/angebot#prozess-check"
        class="inline-flex items-center rounded-md bg-white px-6 py-3 text-lg font-medium text-primary transition-colors hover:bg-white/90"
      >
        Prozess-Check anfragen
      </a>
    </Container>
  </section>
</BaseLayout>
